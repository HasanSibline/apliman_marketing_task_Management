generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/@prisma/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                  String                @id @default(uuid())
  name                String                @unique
  slug                String                @unique
  logo                String?
  primaryColor        String                @default("#3B82F6")
  isActive            Boolean               @default(true)
  subscriptionPlan    String                @default("FREE_TRIAL")
  subscriptionStatus  String                @default("ACTIVE")
  subscriptionStart   DateTime              @default(now())
  subscriptionEnd     DateTime?
  monthlyPrice        Float                 @default(0)
  aiApiKey            String?
  aiProvider          String                @default("gemini")
  aiEnabled           Boolean               @default(false)
  maxUsers            Int?
  maxTasks            Int?
  maxStorage          Int?
  billingEmail        String?
  billingAddress      String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  createdBy           String?
  chatSessions        ChatSession[]
  aiUsageStats        CompanyAIUsage[]
  settings            CompanySettings?
  departments         Department[]
  knowledgeSources    KnowledgeSource[]
  objectives          Objective[]
  quarters            Quarter[]
  subscriptionHistory SubscriptionHistory[]
  tasks               Task[]
  teams               Team[]
  tickets             Ticket[]
  users               User[]
  workflows           Workflow[]

  @@map("companies")
}

model Department {
  id        String   @id @default(uuid())
  companyId String
  name      String
  managerId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  manager   User?    @relation("DepartmentManager", fields: [managerId], references: [id])
  tickets   Ticket[] @relation("ReceiverDepartment")
  users     User[]   @relation("UserDepartment")

  @@unique([companyId, name])
  @@map("departments")
}

model Team {
  id        String       @id @default(uuid())
  companyId String
  name      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  members   TeamMember[]
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@map("teams")
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  userId   String
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation("TeamMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model Ticket {
  id                 String          @id @default(uuid())
  ticketNumber       String
  companyId          String
  title              String
  description        String
  type               TicketType      @default(GENERAL)
  status             TicketStatus    @default(PENDING_REQ_MGR)
  priority           String          @default("MEDIUM")
  isInternal         Boolean         @default(false)
  requesterId        String
  requesterManagerId String?
  receiverDeptId     String
  receiverManagerId  String?
  assigneeId         String?
  amount             Float?
  providerName       String?
  deadline           DateTime?
  metadata           Json?           @default("{}")
  isArchived         Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  taskId             String?         @unique
  comments           TicketComment[]
  attachments        TicketAttachment[]
  assignee           User?           @relation("TicketAssignee", fields: [assigneeId], references: [id])
  company            Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  receiverDept       Department      @relation("ReceiverDepartment", fields: [receiverDeptId], references: [id])
  receiverManager    User?           @relation("TicketReceiverManager", fields: [receiverManagerId], references: [id])
  requester          User            @relation("TicketRequester", fields: [requesterId], references: [id])
  requesterManager   User?           @relation("TicketRequesterManager", fields: [requesterManagerId], references: [id])
  task               Task?           @relation(fields: [taskId], references: [id])

  @@map("tickets")
}

model TicketAttachment {
  id         String   @id @default(uuid())
  ticketId   String
  fileName   String
  filePath   String
  fileType   String
  fileSize   Int
  mimeType   String
  uploadedAt DateTime @default(now())
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_attachments")
}

model TicketComment {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  comment   String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@map("ticket_comments")
}

model Plan {
  id         String   @id @default(uuid())
  name       String   @unique
  maxUsers   Int      @default(10)
  maxTasks   Int      @default(100)
  maxStorage Int      @default(5)
  price      Float    @default(0)
  aiEnabled  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("plans")
}

model CompanySettings {
  id                 String  @id @default(uuid())
  companyId          String  @unique
  secondaryColor     String  @default("#6B7280")
  accentColor        String  @default("#10B981")
  customDomain       String?
  favicon            String?
  analyticsEnabled   Boolean @default(true)
  chatEnabled        Boolean @default(true)
  apiAccess          Boolean @default(false)
  timezone           String  @default("UTC")
  dateFormat         String  @default("MM/DD/YYYY")
  language           String  @default("en")
  emailNotifications Boolean @default(true)
  webhookUrl         String?
  company            Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

model SubscriptionHistory {
  id          String   @id @default(uuid())
  companyId   String
  action      String
  fromPlan    String?
  toPlan      String
  amount      Float?
  reason      String?
  performedBy String
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("subscription_history")
}

model CompanyAIUsage {
  id           String   @id @default(uuid())
  companyId    String
  date         DateTime @default(now())
  messageCount Int      @default(0)
  tokensUsed   Int      @default(0)
  cost         Float    @default(0)
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
  @@map("company_ai_usage")
}

model User {
  id                  String            @id @default(uuid())
  companyId           String?
  email               String
  name                String
  password            String
  role                UserRole          @default(EMPLOYEE)
  position            String?
  status              UserStatus        @default(OFFLINE)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  lastActiveAt        DateTime?
  departmentId        String?
  isTicketApprover    Boolean           @default(false)
  managerId           String?
  avatar              String?
  strategyAccess      StrategyAccess    @default(NONE)
  chatSessions        ChatSession[]
  managedDepartment   Department?       @relation("DepartmentManager")
  knowledgeSources    KnowledgeSource[] @relation("KnowledgeSourceCreator")
  notifications       Notification[]
  approvalsRequested  PhaseApproval[]   @relation("ApprovalRequester")
  approvalsReviewed   PhaseApproval[]   @relation("ApprovalReviewer")
  phaseHistory        PhaseHistory[]
  assignedSubtasks    Subtask[]
  assignedByMe        TaskAssignment[]  @relation("TaskAssigner")
  taskAssignments     TaskAssignment[]  @relation("TaskAssignments")
  taskComments        TaskComment[]
  assignedTasks       Task[]            @relation("TaskAssignee")
  createdTasks        Task[]            @relation("TaskCreator")
  teamMemberships     TeamMember[]      @relation("TeamMemberships")
  ticketComments      TicketComment[]
  assignedTickets     Ticket[]          @relation("TicketAssignee")
  receivedTicketsMgr  Ticket[]          @relation("TicketReceiverManager")
  requestedTickets    Ticket[]          @relation("TicketRequester")
  requestedTicketsMgr Ticket[]          @relation("TicketRequesterManager")
  chatContext         UserChatContext?
  company             Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department          Department?       @relation("UserDepartment", fields: [departmentId], references: [id])
  manager             User?             @relation("UserManager", fields: [managerId], references: [id])
  directReports       User[]            @relation("UserManager")
  createdWorkflows    Workflow[]        @relation("WorkflowCreator")

  @@unique([email, companyId])
  @@map("users")
}

model Task {
  id             String           @id @default(uuid())
  companyId      String
  title          String
  description    String
  taskType       String?
  workflowId     String?
  currentPhaseId String?
  phase          TaskPhase        @default(PENDING_APPROVAL)
  goals          String?
  priority       Int              @default(1)
  dueDate        DateTime?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  assignedToId   String?
  createdById    String
  parentTaskId   String?
  subtaskId      String?          @unique
  quarterId      String?
  objectiveId    String?
  rolledOverFrom String?
  isRolledOver   Boolean          @default(false)
  keyResultId    String?
  taskNumber     String?          @unique
  notifications  Notification[]
  approvals      PhaseApproval[]
  phaseHistory   PhaseHistory[]
  subtasks       Subtask[]
  assignments    TaskAssignment[]
  comments       TaskComment[]
  blocking       TaskDependency[] @relation("DependencyBlockerTask")
  blockedBy      TaskDependency[] @relation("DependencyBlockedTask")
  files          TaskFile[]
  assignedTo     User?            @relation("TaskAssignee", fields: [assignedToId], references: [id])
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy      User             @relation("TaskCreator", fields: [createdById], references: [id])
  currentPhase   Phase?           @relation(fields: [currentPhaseId], references: [id])
  keyResult      KeyResult?       @relation(fields: [keyResultId], references: [id])
  objective      Objective?       @relation(fields: [objectiveId], references: [id])
  parentTask     Task?            @relation("ParentChildTasks", fields: [parentTaskId], references: [id])
  childTasks     Task[]           @relation("ParentChildTasks")
  quarter        Quarter?         @relation(fields: [quarterId], references: [id])
  linkedSubtask  Subtask?         @relation("TaskSubtaskLink", fields: [subtaskId], references: [id])
  workflow       Workflow?        @relation(fields: [workflowId], references: [id])
  ticket         Ticket?

  @@unique([companyId, taskNumber])
  @@map("tasks")
}

model TaskAssignment {
  id           String   @id @default(uuid())
  taskId       String
  userId       String
  assignedAt   DateTime @default(now())
  assignedById String?
  assignedBy   User?    @relation("TaskAssigner", fields: [assignedById], references: [id])
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user         User     @relation("TaskAssignments", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@map("task_assignments")
}

model TaskFile {
  id         String   @id @default(uuid())
  taskId     String
  fileName   String
  filePath   String
  fileType   String
  fileSize   Int
  mimeType   String
  uploadedAt DateTime @default(now())
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_files")
}

model TaskComment {
  id        String         @id @default(uuid())
  taskId    String
  userId    String
  comment   String
  createdAt DateTime       @default(now())
  images    CommentImage[]
  task      Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id])

  @@map("task_comments")
}

model CommentImage {
  id        String      @id @default(uuid())
  commentId String
  data      String
  mimeType  String
  size      Int
  createdAt DateTime    @default(now())
  comment   TaskComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@map("comment_images")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  taskId    String?
  subtaskId String?
  phaseId   String?
  type      String
  title     String
  message   String
  actionUrl String?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  phase     Phase?    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  subtask   Subtask?  @relation(fields: [subtaskId], references: [id], onDelete: Cascade)
  task      Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Workflow {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  taskType    String
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  color       String   @default("#3B82F6")
  icon        String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  phases      Phase[]
  tasks       Task[]
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("WorkflowCreator", fields: [createdById], references: [id])

  @@unique([name, companyId])
  @@map("workflows")
}

model Phase {
  id               String          @id @default(uuid())
  workflowId       String
  name             String
  description      String?
  order            Int
  color            String          @default("#6B7280")
  allowedRoles     String[]        @default([])
  allowedUsers     String[]        @default([])
  autoAssignRole   String?
  autoAssignUserId String?
  isStartPhase     Boolean         @default(false)
  isEndPhase       Boolean         @default(false)
  requiresApproval Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  notifications    Notification[]
  approvals        PhaseApproval[]
  workflow         Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  subtasks         Subtask[]
  tasks            Task[]
  transitionsFrom  Transition[]    @relation("FromPhase")
  transitionsTo    Transition[]    @relation("ToPhase")

  @@unique([workflowId, order])
  @@map("phases")
}

model Transition {
  id          String   @id @default(uuid())
  fromPhaseId String
  toPhaseId   String
  name        String?
  conditions  Json?
  notifyRoles String[] @default([])
  notifyUsers String[] @default([])
  createdAt   DateTime @default(now())
  fromPhase   Phase    @relation("FromPhase", fields: [fromPhaseId], references: [id], onDelete: Cascade)
  toPhase     Phase    @relation("ToPhase", fields: [toPhaseId], references: [id], onDelete: Cascade)

  @@unique([fromPhaseId, toPhaseId])
  @@map("transitions")
}

model Subtask {
  id             String         @id @default(uuid())
  taskId         String
  title          String
  description    String?
  order          Int
  phaseId        String?
  assignedToId   String?
  suggestedRole  String?
  isCompleted    Boolean        @default(false)
  completedAt    DateTime?
  dueDate        DateTime?
  estimatedHours Float?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  notifications  Notification[]
  assignedTo     User?          @relation(fields: [assignedToId], references: [id])
  phase          Phase?         @relation(fields: [phaseId], references: [id])
  task           Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  linkedTask     Task?          @relation("TaskSubtaskLink")

  @@map("subtasks")
}

model PhaseHistory {
  id          String   @id @default(uuid())
  taskId      String
  fromPhaseId String?
  toPhaseId   String
  movedById   String
  comment     String?
  movedAt     DateTime @default(now())
  movedBy     User     @relation(fields: [movedById], references: [id])
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("phase_history")
}

model PhaseApproval {
  id            String    @id @default(uuid())
  taskId        String
  phaseId       String
  requestedById String
  status        String    @default("PENDING")
  reviewedById  String?
  reviewComment String?
  requestedAt   DateTime  @default(now())
  reviewedAt    DateTime?
  phase         Phase     @relation(fields: [phaseId], references: [id])
  requestedBy   User      @relation("ApprovalRequester", fields: [requestedById], references: [id])
  reviewedBy    User?     @relation("ApprovalReviewer", fields: [reviewedById], references: [id])
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("phase_approvals")
}

model SystemSettings {
  id               String   @id @default(uuid())
  maxFileSize      Int      @default(5242880)
  allowedFileTypes String   @default("image/jpeg,image/png,image/webp,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document")
  sessionTimeout   Int      @default(480)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("system_settings")
}

model KnowledgeSource {
  id            String              @id @default(uuid())
  companyId     String
  name          String
  url           String
  type          KnowledgeSourceType
  description   String?
  isActive      Boolean             @default(true)
  content       String?
  lastScraped   DateTime?
  scrapingError String?
  metadata      Json?
  priority      Int                 @default(1)
  createdById   String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy     User                @relation("KnowledgeSourceCreator", fields: [createdById], references: [id])

  @@map("knowledge_sources")
}

model ChatSession {
  id        String        @id @default(uuid())
  companyId String
  userId    String
  title     String        @default("New Chat")
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  endedAt   DateTime?
  messages  ChatMessage[]
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model UserChatContext {
  id        String   @id @default(uuid())
  userId    String   @unique
  context   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_chat_contexts")
}

model Quarter {
  id         String        @id @default(uuid())
  companyId  String
  name       String
  year       Int
  startDate  DateTime
  endDate    DateTime
  status     QuarterStatus @default(UPCOMING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  objectives Objective[]
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks      Task[]

  @@unique([companyId, name, year])
  @@map("quarters")
}

model Objective {
  id          String          @id @default(uuid())
  companyId   String
  quarterId   String?
  title       String
  description String?
  ownerId     String?
  status      ObjectiveStatus @default(ON_TRACK)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  keyResults  KeyResult[]
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quarter     Quarter?        @relation(fields: [quarterId], references: [id])
  tasks       Task[]

  @@map("objectives")
}

model KeyResult {
  id           String    @id @default(uuid())
  objectiveId  String
  title        String
  unit         String    @default("number")
  startValue   Float     @default(0)
  targetValue  Float
  currentValue Float     @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  objective    Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  tasks        Task[]

  @@map("key_results")
}

model TaskDependency {
  id        String   @id @default(uuid())
  taskId    String
  blockerId String
  createdAt DateTime @default(now())
  blocker   Task     @relation("DependencyBlockerTask", fields: [blockerId], references: [id], onDelete: Cascade)
  dependent Task     @relation("DependencyBlockedTask", fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, blockerId])
  @@map("task_dependencies")
}

enum TicketStatus {
  PENDING_REQ_MGR
  PENDING_REC_MGR
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum TicketType {
  GENERAL
  PURCHASE_ORDER
  IT_SUPPORT
  DESIGN_REQUEST
  LEGAL_CONTRACT
  MARKETING_ASSET
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  ADMIN
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  AWAY
  OFFLINE
  RETIRED
}

enum TaskPhase {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum KnowledgeSourceType {
  OWN_COMPANY
  COMPETITOR
}

enum QuarterStatus {
  UPCOMING
  ACTIVE
  CLOSED
}

enum ObjectiveStatus {
  ON_TRACK
  AT_RISK
  OFF_TRACK
  COMPLETED
  CANCELLED
}

enum StrategyAccess {
  NONE
  READ
  EDIT
}
