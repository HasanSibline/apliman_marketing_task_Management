# Database - Use Neon.tech for free PostgreSQL (https://neon.tech)
# Get your connection string from Neon dashboard (use "Pooled connection" not "Direct")
# Example: postgres://user:pass@ep-xxx-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://username:password@localhost:5432/taskmanagement"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# AI Service
AI_SERVICE_URL="https://apliman-marketing-task-management.onrender.com"

# AI Service Authentication
# Generate a strong random secret and set it in BOTH the backend AND the AI service
# e.g.  openssl rand -hex 32
AI_SERVICE_SECRET="change-this-to-a-strong-random-secret"

# File Upload Configuration
UPLOAD_PATH="./uploads"
MAX_FILE_SIZE=5242880

# Server Configuration
PORT=3001
NODE_ENV="development"

# CORS Configuration
FRONTEND_URL="https://apliman-marketing-task-management.pages.dev"

# Session Configuration
SESSION_TIMEOUT=480

# Cloudinary - For permanent file storage (https://cloudinary.com)
# Get these from your Cloudinary dashboard settings
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
