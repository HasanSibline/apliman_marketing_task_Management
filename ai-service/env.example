# AI Service Configuration
PORT=8001
ENVIRONMENT=development

# AI Provider Configuration
# IMPORTANT: AI API keys are NOT configured here. Every AI request must carry a
# company-specific key that a super admin assigned via the admin panel. The service
# never uses environment/platform keys — GOOGLE_API_KEY / GROQ_API_KEY are intentionally
# unused at runtime. Only the model names below are read from the environment.
GEMINI_MODEL=gemini-2.0-flash  # Optional, defaults to gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile  # Optional, defaults to llama-3.3-70b-versatile

# Model Configuration
MODEL_CACHE_DIR=./models
MAX_SUMMARY_LENGTH=150
DEFAULT_TEMPERATURE=0.7

# Rate Limiting
RATE_LIMIT_REQUESTS=60  # requests per minute
RATE_LIMIT_INTERVAL=60  # interval in seconds

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=1  # seconds

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600  # seconds

# OCR Configuration (optional)
TESSERACT_CMD=/usr/bin/tesseract

# Logging
LOG_LEVEL=INFO

# CORS Configuration - restrict to backend server origins only (not the browser frontend)
ALLOWED_ORIGINS=http://localhost:3001,https://your-backend.onrender.com

# AI Service Authentication
# Must match AI_SERVICE_SECRET in the backend .env
# Generate with: openssl rand -hex 32
AI_SERVICE_SECRET=change-this-to-a-strong-random-secret